{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentient-os.local/schemas/component-contract.schema.json",
  "title": "Sentient OS Component Contract",
  "description": "Governance contract for approved Sentient OS Foundation components.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "category",
    "description",
    "architectural_role",
    "responsibility",
    "slots",
    "variants",
    "states",
    "token_dependencies",
    "accessibility",
    "composition_rules",
    "anti_patterns",
    "governance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pf-[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "pattern": "^PF[A-Za-z]+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "surface",
        "layout",
        "navigation",
        "action",
        "status",
        "data",
        "form",
        "feedback",
        "overlay",
        "timeline"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "architectural_role": {
      "type": "string",
      "enum": [
        "room",
        "wall",
        "floor",
        "corridor",
        "control-surface",
        "instrument",
        "ledger",
        "road",
        "lobby",
        "temporary-chamber",
        "side-room",
        "internal-zone",
        "intake-desk",
        "unoccupied-room",
        "signal",
        "circulation"
      ]
    },
    "responsibility": {
      "type": "string",
      "minLength": 1
    },
    "slots": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "variants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "token_dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "accessibility": {
      "type": "object"
    },
    "composition_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "governance": {
      "type": "object",
      "required": [
        "foundation_component",
        "allowed_density_modes",
        "allowed_architectural_families"
      ],
      "properties": {
        "foundation_component": {
          "type": "boolean"
        },
        "allowed_density_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["compact", "standard", "focus", "executive"]
          }
        },
        "allowed_architectural_families": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Command Tower",
              "Glass Atrium",
              "Blueprint Studio",
              "Signal Terminal",
              "Executive Gallery",
              "Horizon Workspace"
            ]
          }
        },
        "status_mappings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
